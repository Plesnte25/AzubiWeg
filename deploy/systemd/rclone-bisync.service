[Unit]
Description=rclone bisync OneDrive vault <-> local (one pass)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=azubiweg
ExecStart=/usr/bin/rclone bisync onedrive:Apps/remotely-save/German /opt/azubiweg/vaults/sharjeel --filters-file=/opt/azubiweg/repo/deploy/rclone-filter.txt --resilient
