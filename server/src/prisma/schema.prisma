generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  passwordHash       String
  name               String
  vaultPath          String?
  // when the default document checklist was seeded; guards against re-seeding
  // after the user deletes items
  checklistSeededAt  DateTime?
  // same idea for the CEFR syllabus (learning hub)
  learningSeededAt   DateTime?
  // which revision of DEFAULT_SYLLABUS_ITEMS this user has; a bump triggers a
  // reseed that preserves completions by title match
  syllabusVersion    Int                  @default(0)
  createdAt          DateTime             @default(now())
  words              Word[]
  cvs                Cv[]
  applications       Application[]
  checklistItems     ChecklistItem[]
  files              UploadedFile[]
  syllabusItems      SyllabusItem[]
  studySources       StudySource[]
  selfTestResults    SelfTestResult[]
  externalAccounts   ExternalAccount[]
  // real calendar date Day 1 was activated on; null = roadmap not started
  roadmapStartedAt   DateTime?            @db.Date
  // which revision of DEFAULT_ROADMAP_DAYS this user's materialized days
  // match; a bump reseeds content/tasks but never re-derives dates
  roadmapVersion     Int                  @default(0)
  roadmapDays        RoadmapDay[]
  lastLoginAt        DateTime?
  activityPings      ActivityPing[]
  dailyActiveMinutes DailyActiveMinutes[]
  // stored (not derived, unlike most stats here) per explicit request — kept
  // in sync by always writing it in the same transaction as the badge/bonus
  // event that earned it (services/gamification)
  points             Int                  @default(0)
  badges             UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // key into services/gamification/badge-defaults.ts's static list
  badgeKey   String
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeKey])
}

// short-lived — folded into DailyActiveMinutes within a day, never outlives
// that (no separate prune job needed)
model ActivityPing {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pingedAt DateTime @default(now())

  @@index([userId, pingedAt])
}

// permanent, one row per user per active local day
model DailyActiveMinutes {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date    DateTime @db.Date
  minutes Int

  @@unique([userId, date])
}

model Word {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  headword   String
  // lowercased headword, mirrors add_word.py's case-insensitive dedupe key
  sortKey    String
  meaning    String?
  ipa        String?
  grammar    String?
  // inflected forms noted on a lemma card ("bist = second-person singular present of sein")
  form       String?
  example    String?
  audioPath  String?
  lesson     String?
  srDue      DateTime?   @db.Date
  srInterval Int?
  srEase     Int?
  // the exact card block from the vault (card line + SR comment lines) so
  // unmodeled markdown survives round-trips byte-for-byte
  rawBlock   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  reviews    ReviewLog[]

  @@unique([userId, sortKey])
}

model ReviewLog {
  id            String   @id @default(cuid())
  wordId        String
  word          Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  grade         Grade
  reviewedAt    DateTime @default(now())
  intervalAfter Int
}

enum Grade {
  hard
  good
  easy
}

model UploadedFile {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistItemId String?
  checklistItem   ChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  syllabusItemId  String?
  syllabusItem    SyllabusItem?  @relation(fields: [syllabusItemId], references: [id], onDelete: Cascade)
  studySourceId   String?
  studySource     StudySource?   @relation(fields: [studySourceId], references: [id], onDelete: Cascade)
  roadmapTaskId   String?
  roadmapTask     RoadmapTask?   @relation(fields: [roadmapTaskId], references: [id], onDelete: Cascade)
  kind            FileKind       @default(document)
  originalName    String
  // server-generated "<cuid>.<whitelisted ext>" under data/uploads/<userId>/;
  // never derived from originalName, so paths are traversal-safe by construction
  storedName      String
  mimeType        String
  size            Int
  createdAt       DateTime       @default(now())
}

enum FileKind {
  document
  cv_photo
  // a user-recorded speaking-practice clip (see RoadmapTask.skill == speaking)
  audio_recording
}

model Cv {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  template     CvTemplate    @default(lebenslauf)
  // the whole CV as one document (CvContent, zod-validated on write) — the
  // form edits one object, PUT saves one object, react-pdf renders one object
  content      Json
  // UploadedFile.id with kind=cv_photo; kept out of content so the file
  // lifecycle stays queryable
  photoFileId  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

enum CvTemplate {
  lebenslauf
  ats
}

model Application {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  position     String
  location     String?
  url          String?
  contactName  String?
  contactEmail String?
  notes        String?
  // which portal the application lives on (e.g. "GoAusbildung") + a one-click
  // link to it; no sync — the portals expose no public API
  platform     String?
  platformUrl  String?
  status       ApplicationStatus  @default(wishlist)
  // position within its status column, contiguous per (userId, status)
  sortOrder    Int                @default(0)
  appliedAt    DateTime?          @db.Date
  cvId         String?
  cv           Cv?                @relation(fields: [cvId], references: [id], onDelete: SetNull)
  events       ApplicationEvent[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId, status, sortOrder])
}

enum ApplicationStatus {
  wishlist
  applied
  interview
  offer
  rejected
}

model ApplicationEvent {
  id            String               @id @default(cuid())
  applicationId String
  application   Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          ApplicationEventType
  note          String?
  // populated for status_change events
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus?
  occurredAt    DateTime             @default(now())
}

enum ApplicationEventType {
  created
  status_change
  note
  interview
  follow_up
}

model ChecklistItem {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    ChecklistCategory @default(other)
  status      ChecklistStatus   @default(todo)
  expiresAt   DateTime?         @db.Date
  sortOrder   Int               @default(0)
  // came from the seeded default set
  isDefault   Boolean           @default(false)
  files       UploadedFile[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum ChecklistCategory {
  identity
  education
  visa
  finances
  insurance
  application
  after_arrival
  other
}

enum ChecklistStatus {
  todo
  in_progress
  done
  // e.g. "blocked account OR salary proof" — mark the unused path n/a
  not_applicable
}

model SyllabusItem {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  level          CefrLevel
  category       SyllabusCategory
  // topic heading the item (subtopic) is grouped under, e.g. "Verbs: present tense"
  theme          String?
  title          String
  description    String?
  // pedagogical order within the level; "next up" = first incomplete
  sortOrder      Int              @default(0)
  // doubles as the activity date for the learning streak; null = not done
  completedAt    DateTime?
  // Grammar Notebook — the user's OWN notes, never authored content. Unlike
  // title/description these must survive a SYLLABUS_VERSION reseed untouched
  // (see the carry-over map in routes/learning.ts), since a version bump only
  // ever replaces authored content, not what the user has written themselves.
  examples       String?
  exceptions     String?
  commonMistakes String?
  files          UploadedFile[]
  roadmapTasks   RoadmapTask[]
  createdAt      DateTime         @default(now())

  @@index([userId, level, sortOrder])
}

enum CefrLevel {
  a1
  a2
  b1
}

enum SyllabusCategory {
  grammar
  vocab_theme
  skill
}

model StudySource {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           StudySourceType   @default(other)
  title          String
  url            String?
  level          CefrLevel?
  // null = open-ended (e.g. a channel with no fixed lesson count)
  // denormalized from units when units exist (recomputed on every unit
  // mutation); authoritative for open-ended counter sources without units
  totalUnits     Int?
  completedUnits Int               @default(0)
  notes          String?
  logs           StudySourceLog[]
  units          StudySourceUnit[]
  files          UploadedFile[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model StudySourceUnit {
  id          String      @id @default(cuid())
  sourceId    String
  source      StudySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  position    Int
  title       String
  // YouTube video id when scraped from a playlist; drives per-lesson links
  // and the client-side thumbnail (img.youtube.com/vi/<id>/mqdefault.jpg)
  videoId     String?
  // direct lesson link for non-YouTube sources (e.g. Nicos Weg lesson pages)
  url         String?
  // free-form per-lesson notes, edited inline in the lesson list
  notes       String?
  // null = not done
  completedAt DateTime?

  @@unique([sourceId, position])
}

enum StudySourceType {
  youtube
  nicos_weg
  duolingo
  other
}

// immutable progress log; its loggedAt dates feed the learning streak
model StudySourceLog {
  id       String      @id @default(cuid())
  sourceId String
  source   StudySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  delta    Int         @default(1)
  loggedAt DateTime    @default(now())

  @@index([sourceId])
}

// self-tests measure level progress only — they never touch ReviewLog,
// the SR schedule fields on Word, or the Obsidian vault
model SelfTestResult {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        SelfTestKind  @default(vocab)
  direction   QuizDirection @default(de_to_meaning)
  // lesson filter used for the quiz, if any (legacy vocab quizzes)
  lesson      String?
  // active level the mixed session targeted
  level       CefrLevel?
  // string[] of question ids asked (bank ids + "w:<wordId>:<type>");
  // the last few results' ids are excluded from the next session (no repeats)
  questionIds Json?
  // [{ topic, level, correct, total }] for history display
  breakdown   Json?
  score       Int
  total       Int
  takenAt     DateTime      @default(now())

  @@index([userId, takenAt])
}

enum SelfTestKind {
  // legacy word-only MCQ
  vocab
  // session-engine test: bank + vocab questions, mixed formats
  mixed
}

enum QuizDirection {
  de_to_meaning
  meaning_to_de
}

// day-by-day study roadmap: a hand-authored 26-week (182-day) A0→B1 plan,
// materialized to real calendar dates per user on activation. Backlog/overdue
// state is intentionally never stored here — it's computed on read from
// `date` vs "today" (see services/learning/roadmap.ts), same philosophy as
// expiryStatus/levelStates elsewhere in the app.
model RoadmapDay {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // stable identity back to DEFAULT_ROADMAP_DAYS; 0-based from roadmapStartedAt
  dayOffset      Int
  // = roadmapStartedAt + dayOffset days; always re-derived from that, never
  // independently adjusted, so version-bump reseeds can't drift a day's date
  date           DateTime      @db.Date
  theme          String?
  tasks          RoadmapTask[]
  // stamped once, the first time every task on this day is completedAt !=
  // null; never cleared by later unchecking a task — a fact, not a toggle.
  // Gates the one-time +5 point "day complete" bonus (services/gamification).
  bonusAwardedAt DateTime?

  @@unique([userId, dayOffset])
  @@index([userId, date])
}

enum RoadmapTaskType {
  generic
  vocab // links to /review (existing SRS)
  study_source // links to /learning Sources tab (e.g. Nicos Weg)
  milestone_test // auto-launches a self-test session
}

// which practice bucket a task belongs to — powers the Writing/Speaking/
// Listening/Reading/Deutschland-Context "journal" views (a filtered read
// over RoadmapTask, not a separate model per skill). Set structurally by
// roadmap-defaults.ts's week-builder functions, never inferred from title
// text at query time.
enum RoadmapSkill {
  grammar
  vocab
  listening
  speaking
  writing
  reading
  bureaucracy // "Deutschland Context"
  milestone
  reflection // rest-day / weekly-reflection tasks
}

model RoadmapTask {
  id             String          @id @default(cuid())
  dayId          String
  day            RoadmapDay      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  sortOrder      Int             @default(0)
  type           RoadmapTaskType @default(generic)
  skill          RoadmapSkill?
  title          String
  description    String?
  // user's own free-text reflection/log for this task
  journalEntry   String?
  // self-reported minutes spent, entered (optionally) when marking complete
  minutesSpent   Int?
  completedAt    DateTime?
  files          UploadedFile[]
  // set only for grammar/vocab tasks generated from the syllabus (see
  // services/learning/roadmap-generator.ts); SetNull (not Cascade) — a
  // SYLLABUS_VERSION reseed deletes and recreates SyllabusItem rows, which
  // must never take a roadmap day down with it. completedAt here and on the
  // linked SyllabusItem are the same fact, kept in sync by
  // services/learning/completion-sync.ts, never independently toggled.
  syllabusItemId String?
  syllabusItem   SyllabusItem?   @relation(fields: [syllabusItemId], references: [id], onDelete: SetNull)

  @@index([dayId])
  @@index([skill])
  @@index([syllabusItemId])
}

// quick links to application portals (GoAusbildung etc.) — links only, not
// synced accounts: none of these platforms offer a public API today
model ExternalAccount {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String
  url           String
  // stamped when the user opens the portal from the app; drives the
  // "haven't checked X in a while" notification
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
}
